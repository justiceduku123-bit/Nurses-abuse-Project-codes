# ── 0. INSTALL & LOAD PACKAGES ──────────────────────────────
packages <- c("readxl", "dplyr", "tidyr", "ggplot2", "forcats",
              "scales", "knitr", "janitor", "stringr", "ggmosaic",
              "likert", "psych", "vcd", "RColorBrewer")

install_if_missing <- function(pkg) {
  if (!requireNamespace(pkg, quietly = TRUE)) install.packages(pkg)
}
invisible(lapply(packages, install_if_missing))

library(readxl); library(dplyr); library(tidyr); library(ggplot2)
library(forcats); library(scales); library(janitor); library(stringr)
library(psych); library(vcd); library(RColorBrewer)

# ── 1. LOAD & CLEAN DATA ─────────────────────────────────────
df_raw <- read_excel("C:/Users/DELL/Downloads/NURSES_ABUSE_COMPLETED_92.xlsx")

# Trim whitespace from all column names
df <- df_raw %>% clean_names()

# Rename columns to short, readable names
df <- df %>%
  rename(
    gender               = gender,
    age_group            = age_group,
    marital_status       = marital_status,
    prof_category        = professional_category,
    experience           = years_of_work_experience,
    department           = x7_department_unit,
    ever_abused          = have_you_ever_experienced_abuse_from_patients_or_their_relatives_while_performing_your_duties,
    abuse_frequency      = if_yes_how_often_do_you_experience_abuse,
    abuse_type           = what_type_of_abuse_have_you_experienced,
    perpetrator          = who_are_the_most_common_perpetrators_of_abuse,
    abuse_location       = where_does_abuse_most_frequently_occur_in_the_hospital,
    org1_waiting         = long_waiting_time_contributes_to_patient_frustration,
    org2_staffshortage   = staff_shortages_increase_the_risk_of_abuse,
    org3_overcrowding    = overcrowding_in_the_hospital_leads_to_abusive_behavior,
    org4_workload        = heavy_workload_affects_nurses_ability_to_attend_to_patients_promptly,
    org5_security        = lack_of_security_personnel_contributes_to_abuse,
    org6_policy          = absence_of_clear_hospital_policies_encourages_abusive_behavior,
    comm1_poor_comm      = poor_communication_between_nurses_and_patients_contributes_to_abuse,
    comm2_procedures     = patients_become_abusive_when_they_do_not_understand_medical_procedures,
    comm3_waiting_info   = lack_of_information_about_waiting_time_causes_frustration,
    comm4_language       = language_barriers_lead_to_misunderstandings,
    comm5_attention      = patients_expect_immediate_attention_from_nurses,
    likely_abuser        = which_group_is_more_likely_to_abuse_nurses,
    main_factor          = in_your_opinion_which_factor_most_contributes_to_abusive_behavior,
    reduce_measures      = which_of_the_following_measures_can_help_reduce_abuse_against_nurses,
    mgmt_protection      = do_you_think_hospital_management_does_enough_to_protect_nurses_from_abuse,
    data_type            = data_type
  )

# Ordered Likert factor levels
likert_levels <- c("Strongly Disagree", "Disagree", "Neutral", "Agree", "Strongly Agree")

likert_cols <- c("org1_waiting", "org2_staffshortage", "org3_overcrowding",
                 "org4_workload", "org5_security", "org6_policy",
                 "comm1_poor_comm", "comm2_procedures", "comm3_waiting_info",
                 "comm4_language", "comm5_attention")

df <- df %>%
  mutate(across(all_of(likert_cols),
                ~ factor(.x, levels = likert_levels, ordered = TRUE)))
likert_to_num <- function(x) {
  dplyr::recode(x,
                "Strongly Disagree" = 1L,
                "Disagree"          = 2L,
                "Neutral"           = 3L,
                "Agree"             = 4L,
                "Strongly Agree"    = 5L
)
}

all_items <- df %>% select(all_of(likert_cols))
alpha_overall <- psych::alpha(all_items)
print(alpha_overall)

cat("✔  Data loaded:", nrow(df), "observations,", ncol(df), "variables\n")

