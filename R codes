cat("\n\n══════════════════════════════════════════════\n")
cat("  OBJECTIVE 1: PREVALENCE OF ABUSE\n")
cat("══════════════════════════════════════════════\n")

## 1a. Overall prevalence
prev_tbl <- df %>%
  count(ever_abused) %>%
  mutate(pct = n / sum(n) * 100)
print(prev_tbl)

cat("\nPrevalence of abuse:", round(prev_tbl$pct[prev_tbl$ever_abused == "Yes"], 1), "%\n")

## 1b. Frequency of abuse (among those abused)
freq_tbl <- df %>%
  filter(ever_abused == "Yes") %>%
  count(abuse_frequency) %>%
  mutate(pct = n / sum(n) * 100,
         abuse_frequency = factor(abuse_frequency,
                                  levels = c("Rarely", "Sometimes", "Often", "Very often")))
print(freq_tbl)

## 1c. Type of abuse
