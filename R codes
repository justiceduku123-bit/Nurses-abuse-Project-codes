## 4b. Cross-tabulation: each demographic × ever_abused + Chi-square test
cat("\n\n--- Chi-Square Tests: Sociodemographic vs Ever Abused ---\n")
for (v in demo_vars) {
  cat("\n", v, "× ever_abused:\n")
  ct <- table(df[[v]], df$ever_abused)
  print(ct)
  test <- chisq.test(ct, simulate.p.value = TRUE)
  cat("  Chi-sq =", round(test$statistic, 3),
      "| p-value =", round(test$p.value, 4), "\n")
}

## 4c. Cross-tab: demographics × abuse_frequency (among abused)
df_abused <- df %>% filter(ever_abused == "Yes")
cat("\n\n--- Abuse Frequency by Demographics (abused only) ---\n")
for (v in demo_vars) {
  cat("\n", v, "× abuse_frequency:\n")
  ct <- table(df_abused[[v]], df_abused$abuse_frequency)
  print(ct)
  if (all(dim(ct) > 1)) {
    test <- chisq.test(ct, simulate.p.value = TRUE)
    cat("  Chi-sq p-value =", round(test$p.value, 4), "\n")
  }
