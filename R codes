cat("  OBJECTIVE 2: ORGANIZATIONAL FACTORS\n")
cat("══════════════════════════════════════════════\n")

org_labels <- c(
  org1_waiting   = "Long waiting time",
  org2_staffshortage = "Staff shortages",
  org3_overcrowding  = "Overcrowding",
  org4_workload      = "Heavy workload",
  org5_security      = "Lack of security",
  org6_policy        = "Absence of clear policies"
)

## 2a. Frequency tables for each organizational factor
for (v in names(org_labels)) {
  cat("\n", org_labels[v], ":\n")
  tbl <- df %>% count(!!sym(v)) %>% mutate(pct = n / sum(n) * 100)
  print(tbl)
}

## 2b. Agreement rates (Agree + Strongly Agree)
org_agreement <- df %>%
  select(all_of(names(org_labels))) %>%
  pivot_longer(everything(), names_to = "factor", values_to = "response") %>%
  mutate(agree = response %in% c("Agree", "Strongly Agree")) %>%
  group_by(factor) %>%
  summarise(
    n_agree = sum(agree, na.rm = TRUE),
    n_total = n(),
    pct_agree = n_agree / n_total * 100
  ) %>%
  mutate(factor_label = org_labels[factor])

print(org_agreement)

## 2c. Mean Likert score per factor (1=SD … 5=SA)
likert_num <- function(x) as.numeric(x)

org_means <- df %>%
  select(all_of(names(org_labels))) %>%
  mutate(across(everything(), likert_num)) %>%
  summarise(across(everything(), ~ mean(.x, na.rm = TRUE))) %>%
  pivot_longer(everything(), names_to = "factor", values_to = "mean_score") %>%
  mutate(factor_label = org_labels[factor])

print(org_means)

## 2d. Chi-square: department × each org factor (agreement binary)
df_org_chi <- df %>%
  mutate(
    org1_agree = org1_waiting %in% c("Agree", "Strongly Agree"),
    org2_agree = org2_staffshortage %in% c("Agree", "Strongly Agree"),
    org3_agree = org3_overcrowding %in% c("Agree", "Strongly Agree"),
    org4_agree = org4_workload %in% c("Agree", "Strongly Agree"),
    org5_agree = org5_security %in% c("Agree", "Strongly Agree"),
    org6_agree = org6_policy %in% c("Agree", "Strongly Agree")
  )

chi_org <- function(var) {
  ct <- table(df_org_chi$department, df_org_chi[[var]])
  chisq.test(ct, simulate.p.value = TRUE)
}

for (v in paste0("org", 1:6, "_agree")) {
  cat("\nChi-square: department vs", v, "\n")
  print(chi_org(v))
}

