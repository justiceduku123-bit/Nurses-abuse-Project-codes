## 4d. Logistic regression: predictors of being abused
df_logit <- df %>%
  mutate(
    abused_bin  = as.integer(ever_abused == "Yes"),
    gender_f    = factor(gender),
    age_f       = factor(age_group),
    marital_f   = factor(marital_status),
    prof_f      = factor(prof_category),
    exp_f       = factor(experience),
    dept_f      = factor(department)
  )

logit_model <- glm(abused_bin ~ gender_f + age_f + prof_f + exp_f + dept_f,
                   data = df_logit, family = binomial)
cat("\n\n--- Logistic Regression: Predictors of Abuse ---\n")
summary(logit_model)
cat("\nOdds Ratios:\n")
print(round(exp(cbind(OR = coef(logit_model), confint.default(logit_model))), 3))

